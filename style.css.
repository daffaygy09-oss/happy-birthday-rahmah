*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:linear-gradient(135deg,#000428,#004e92);
    color:white;
    height:100vh;
    overflow:hidden;
}

.hidden{
    display:none;
}

#loading{
    width:100%;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:35px;
    letter-spacing:3px;
    animation:fade 1.5s infinite;
}

#main{
    width:100%;
    height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
    padding:20px;
}

.title{
    font-size:42px;
    line-height:1.3;
    margin-bottom:20px;
    animation:zoom 1.2s;
}

.subtitle{
    font-size:18px;
    opacity:.9;
    margin-bottom:35px;
}

button{
    padding:15px 45px;
    border:none;
    border-radius:50px;
    background:white;
    color:#004e92;
    font-size:18px;
    font-weight:bold;
    cursor:pointer;
    transition:.3s;
}

button:hover{
    transform:scale(1.08);
}

#birthdayPage{
    width:100%;
    height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    padding:20px;
}

#slide{
    width:260px;
    height:340px;
    object-fit:cover;
    border-radius:20px;
    border:5px solid white;
    box-shadow:0 0 25px rgba(255,255,255,.5);
    animation:zoom 1s;
}

.message{
    margin-top:30px;
    text-align:center;
    max-width:700px;
}

.message h2{
    margin-bottom:20px;
    font-size:30px;
}

#typing{
    font-size:18px;
    line-height:30px;
}

@keyframes zoom{
    from{
        transform:scale(.7);
        opacity:0;
    }
    to{
        transform:scale(1);
        opacity:1;
    }
}

@keyframes fade{
    0%{
        opacity:.3;
    }
    50%{
        opacity:1;
    }
    100%{
        opacity:.3;
    }
}
